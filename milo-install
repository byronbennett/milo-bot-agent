#!/usr/bin/env bash
set -e

detect_default_pnpm_home() {
  case "$(uname -s)" in
    Darwin) echo "$HOME/Library/pnpm" ;;
    *) echo "$HOME/.local/share/pnpm" ;;
  esac
}

ensure_command_exists() {
  local command_name="$1"

  if command -v "$command_name" >/dev/null 2>&1; then
    return 0
  fi

  echo "❌ Missing required command: $command_name"
  exit 1
}

ensure_path_contains() {
  local dir="$1"

  if [[ -z "$dir" ]]; then
    return 0
  fi

  case ":$PATH:" in
    *":$dir:"*) ;;
    *) export PATH="$dir:$PATH" ;;
  esac
}

configure_pnpm_global_locations() {
  local pnpm_home="$1"

  mkdir -p "$pnpm_home" "$pnpm_home/global"
  export PNPM_HOME="$pnpm_home"
  ensure_path_contains "$PNPM_HOME"

  # Persist config for future shells when possible.
  pnpm config set global-bin-dir "$PNPM_HOME" --global >/dev/null 2>&1 || true
  pnpm config set global-dir "$PNPM_HOME/global" --global >/dev/null 2>&1 || true
}

ensure_pnpm_global_bin_dir() {
  local pnpm_global_bin
  pnpm_global_bin="$(pnpm bin --global 2>/dev/null || true)"

  if [[ -z "$pnpm_global_bin" ]]; then
    # Initialize pnpm home/profile settings when available.
    pnpm setup >/dev/null 2>&1 || true
    pnpm_global_bin="$(pnpm bin --global 2>/dev/null || true)"
  fi

  if [[ -z "$pnpm_global_bin" ]]; then
    configure_pnpm_global_locations "${PNPM_HOME:-$(detect_default_pnpm_home)}"
    pnpm_global_bin="$(pnpm bin --global 2>/dev/null || true)"
    pnpm_global_bin="${pnpm_global_bin:-$PNPM_HOME}"
  else
    export PNPM_HOME="${PNPM_HOME:-$pnpm_global_bin}"
  fi

  ensure_path_contains "$pnpm_global_bin"

  if [[ -z "$pnpm_global_bin" ]]; then
    echo "❌ Unable to configure pnpm global bin directory."
    exit 1
  fi

  echo "📌 pnpm global bin directory: $pnpm_global_bin"
}

create_fallback_milo_link() {
  local source_bin="$PWD/dist/bin/milo.js"
  local target_home="${PNPM_HOME:-$(detect_default_pnpm_home)}"
  local target_bin="$target_home/milo"

  mkdir -p "$target_home"
  chmod +x "$source_bin"
  ln -sf "$source_bin" "$target_bin"
  ensure_path_contains "$target_home"

  echo "📌 Created fallback CLI link at $target_bin"
}

link_cli_with_recovery() {
  local output=""
  local status=0

  set +e
  output="$(pnpm link --global 2>&1)"
  status=$?
  set -e
  echo "$output"

  if [[ $status -eq 0 ]]; then
    return 0
  fi

  if [[ "$output" != *"ERR_PNPM_NO_GLOBAL_BIN_DIR"* ]]; then
    return "$status"
  fi

  echo "⚠️  Repairing pnpm global bin configuration and retrying..."
  configure_pnpm_global_locations "${PNPM_HOME:-$(detect_default_pnpm_home)}"
  pnpm setup >/dev/null 2>&1 || true
  ensure_pnpm_global_bin_dir

  set +e
  output="$(pnpm link --global 2>&1)"
  status=$?
  set -e
  echo "$output"

  if [[ $status -eq 0 ]]; then
    return 0
  fi

  if [[ "$output" == *"ERR_PNPM_NO_GLOBAL_BIN_DIR"* ]]; then
    echo "⚠️  Falling back to a direct CLI symlink."
    create_fallback_milo_link
    return 0
  fi

  return "$status"
}

echo ""
echo "🤖 Installing MiloBot Agent..."
echo ""

ensure_command_exists node
ensure_command_exists pnpm

# Ensure pnpm can link global binaries in clean environments.
echo "🧰 Preparing pnpm global bin directory..."
ensure_pnpm_global_bin_dir

# Install dependencies
echo "📦 Installing dependencies..."
pnpm install

# Build and link globally
echo ""
echo "🔨 Building CLI..."
pnpm build
echo "🔗 Linking CLI globally..."
link_cli_with_recovery

echo ""
echo "✅ milo command is now available!"
echo ""

# Run init
if command -v milo >/dev/null 2>&1; then
  exec milo init
fi

# Fallback when global PATH updates have not been loaded by the parent shell yet.
exec pnpm exec milo init
